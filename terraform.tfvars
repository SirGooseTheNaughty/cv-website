# terraform.tfvars
# Configuration for your CV website

# Your domain name (uncomment when ready to use custom domain)
# domain_name = "sergey-v.com"

# S3 bucket name - must be globally unique
bucket_name = "cv-website-sergey-v-prod"

# AWS region for resources (CloudFront will be global)
aws_region = "eu-west-1"

# AWS profile to use
aws_profile = "studio"